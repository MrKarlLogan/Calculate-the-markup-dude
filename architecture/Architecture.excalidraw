    {
      "id": "XNSe6NDy2EZ8xJ5tDmbei",
      "type": "text",
      "x": -262.4082587942438,
      "y": 289.4828197982402,
      "width": 432.02728271484375,
      "height": 161.0913837157565,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
