      "updated": 1773343979175,
      "link": null,
      "locked": false,
      "text": "1. Страница авторизации\n2. Страница конструктора\n3. Админка (создание/\nредактирование/удаление \nтовара). Защищенный роут \nтолько у админа!",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Страница авторизации\n2. Страница конструктора\n3. Админка (создание/\nредактирование/удаление \nтовара). Защищенный роут \nтолько у админа!",
      "autoResize": true,
      "lineHeight": 1.25
